# /etc/nginx/sites-available/sub-aggregator
#
# Two setups are documented below — pick one:
#   A) Direct TLS with Let's Encrypt
#   B) Behind Cloudflare proxy with an Origin Certificate (recommended)
#
# In both cases replace <sub_path> and yourdomain.com with your values.

# ── Option A: Direct TLS (Let's Encrypt) ─────────────────────────────────────
# Your real server IP will be visible in DNS.
# Prerequisites: certbot --nginx -d yourdomain.com

server {
    listen 80;
    server_name yourdomain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name yourdomain.com;

    ssl_certificate     /etc/letsencrypt/live/yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/yourdomain.com/privkey.pem;

    # Only expose the subscription path — everything else returns 404.
    location /<sub_path>/ {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   X-Forwarded-For $remote_addr;
        proxy_set_header   Host $host;
        proxy_read_timeout 30s;
    }
}


# ── Option B: Behind Cloudflare proxy (recommended) ──────────────────────────
# Your real server IP is hidden behind Cloudflare's edge.
# CT logs show Cloudflare's certificate, not yours.
#
# Prerequisites:
#   1. Domain added to Cloudflare, A record set to your server IP with the
#      orange cloud (Proxied) enabled.
#   2. Cloudflare SSL/TLS mode set to "Full (Strict)" in the dashboard.
#   3. Origin Certificate created in Cloudflare dashboard:
#        SSL/TLS → Origin Server → Create Certificate
#      Save the certificate as:  /etc/ssl/cloudflare/origin.pem
#      Save the private key as:  /etc/ssl/cloudflare/origin.key
#   4. Set trusted_proxy to 127.0.0.1 in config.yaml (nginx is on the same
#      machine, so the Go service still sees connections from localhost).

server {
    listen 443 ssl;
    server_name yourdomain.com;

    ssl_certificate     /etc/ssl/cloudflare/origin.pem;
    ssl_certificate_key /etc/ssl/cloudflare/origin.key;

    # Resolve the real client IP from Cloudflare's CF-Connecting-IP header.
    # After this, $remote_addr holds the actual client IP everywhere below.
    real_ip_header     CF-Connecting-IP;

    # Cloudflare IPv4 ranges
    set_real_ip_from   103.21.244.0/22;
    set_real_ip_from   103.22.200.0/22;
    set_real_ip_from   103.31.4.0/22;
    set_real_ip_from   104.16.0.0/13;
    set_real_ip_from   104.24.0.0/14;
    set_real_ip_from   108.162.192.0/18;
    set_real_ip_from   131.0.72.0/22;
    set_real_ip_from   141.101.64.0/18;
    set_real_ip_from   162.158.0.0/15;
    set_real_ip_from   172.64.0.0/13;
    set_real_ip_from   173.245.48.0/20;
    set_real_ip_from   188.114.96.0/20;
    set_real_ip_from   190.93.240.0/20;
    set_real_ip_from   197.234.240.0/22;
    set_real_ip_from   198.41.128.0/17;

    # Cloudflare IPv6 ranges
    set_real_ip_from   2400:cb00::/32;
    set_real_ip_from   2606:4700::/32;
    set_real_ip_from   2803:f800::/32;
    set_real_ip_from   2405:b500::/32;
    set_real_ip_from   2405:8100::/32;
    set_real_ip_from   2a06:98c0::/29;
    set_real_ip_from   2c0f:f248::/32;

    # Block any request that did not arrive through Cloudflare.
    # This prevents bypassing Cloudflare by hitting your server IP directly.
    # The deny all catches everything not matched by Cloudflare ranges above;
    # the real_ip_from ranges above are what set_real_ip_from uses, but for
    # connection-level blocking we use geo in the http block (see below).
    # Simpler alternative: handle this with ufw (see README).

    # Only expose the subscription path — everything else returns 404.
    location /<sub_path>/ {
        proxy_pass         http://127.0.0.1:8000;
        proxy_set_header   X-Forwarded-For $remote_addr;  # now the real client IP
        proxy_set_header   Host $host;
        proxy_read_timeout 30s;
    }
}
